PORT=3000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
# Comma-separated list of allowed frontend origins (production + preview URLs)
# Example: https://agrosense-delta.vercel.app,https://preview-deploy.vercel.app
FRONTEND_URL=http://localhost:5173

OPENWEATHER_API_KEY=your_openweathermap_api_key

# When deploying to production set NODE_ENV=production and COOKIE_SECURE=true
NODE_ENV=development
COOKIE_SECURE=false

CRON_TIMEZONE=Asia/Kolkata
